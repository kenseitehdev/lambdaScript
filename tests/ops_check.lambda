I = FALSE v TRUE
J = FALSE ∨ TRUE

K = (TRUE ^ TRUE) ∧ (FALSE v TRUE)
L = (FALSE ∨ FALSE) v (TRUE ∧ TRUE)
M = TRUE ^ TRUE ∧ TRUE
N = FALSE v FALSE ∨ TRUE

O = TRUE -> TRUE
P = FALSE → TRUE
Q = TRUE <-> TRUE
R = FALSE ↔ FALSE
S = TRUE <=> TRUE
T = TRUE ≡ TRUE
U = TRUE ≣ TRUE

V = ¬¬TRUE ∧ ~FALSE ^ ⌐⌐TRUE
