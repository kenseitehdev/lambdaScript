SHOW = \b.b True False
NOT = \p.p FALSE TRUE
AND = \p q.p q FALSE
OR = \p q.p TRUE q
IMP = \p q.OR (NOT p) q
IFF = \p q.AND (IMP p q) (IMP q p)

A = ~~~~~~~~~~~~~~~TRUE
B = ¬¬¬¬¬¬¬¬¬¬¬¬¬¬¬FALSE
