SHOW = \b.b True False

A = ~~~~~~~~~~~~~~~TRUE
B = ¬¬¬¬¬¬¬¬¬¬¬¬¬¬¬FALSE
C = ⌐⌐⌐⌐⌐⌐⌐⌐TRUE

D = ~¬⌐~¬⌐TRUE
E = ¬~⌐¬~⌐FALSE
F = ~¬⌐~¬⌐~¬⌐TRUE

G = TRUE ^ TRUE
H = TRUE ∧ TRUE
I0 = FALSE v TRUE
J = FALSE ∨ TRUE

K0 = (TRUE ^ TRUE) ∧ (FALSE v TRUE)
L = (FALSE ∨ FALSE) v (TRUE ∧ TRUE)
M = TRUE ^ TRUE ∧ TRUE
N = FALSE v FALSE ∨ TRUE

O = TRUE -> TRUE
P = FALSE → TRUE
Q = TRUE <-> TRUE
R0 = FALSE ↔ FALSE
S0 = TRUE <=> TRUE
T = TRUE ≡ TRUE
U = TRUE ≣ TRUE

V = ¬¬TRUE ∧ ~FALSE ^ ⌐⌐TRUE
W = ~~~~~~~~~~~~~~~(TRUE ∧ FALSE)
X = ¬¬¬¬¬¬¬¬¬¬¬¬¬¬¬(FALSE ∨ TRUE)
Y = ~¬⌐~¬⌐(TRUE -> FALSE)
Z = ⌐⌐⌐⌐(TRUE <-> TRUE)

R = cons (SHOW A) (cons (SHOW B) (cons (SHOW C) (cons (SHOW D) (cons (SHOW E) (cons (SHOW F) (cons (SHOW G) (cons (SHOW H) (cons (SHOW I0) (cons (SHOW J) (cons (SHOW K0) (cons (SHOW L) (cons (SHOW M) (cons (SHOW N) (cons (SHOW O) (cons (SHOW P) (cons (SHOW Q) (cons (SHOW R0) (cons (SHOW S0) (cons (SHOW T) (cons (SHOW U) (cons (SHOW V) (cons (SHOW W) (cons (SHOW X) (cons (SHOW Y) (cons (SHOW Z) nil)))))))))))))))))))))))))
R
